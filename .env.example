# Revolut Business API OAuth credentials (required).
# See https://developer.revolut.com/docs/business/business-api
REVOLUT_CLIENT_ID=your_revolut_client_id
REVOLUT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END PRIVATE KEY-----"
REVOLUT_ISS=https://your-domain.com
REVOLUT_REFRESH_TOKEN=your_refresh_token

# Optional overrides
# REVOLUT_AUD=https://revolut.com
